# Frontend build-time environment variables (Vite).
#
# This file is COMMITTED on purpose: per Lovable's docs, the hosted build reads
# VITE_* variables from a committed .env, not from Secrets, so it must not be
# gitignored. Only PUBLIC / publishable values may live here — never a secret
# key (no sk_*, no service-role key, no private tokens). All VITE_* values are
# embedded into the client bundle and are visible in the browser regardless.

# --- Supabase (public project URL + anon/publishable key) -------------------
# The anon/publishable key is safe in the browser (RLS enforces access) and is
# already the hardcoded fallback in src/integrations/supabase/client.ts.
VITE_SUPABASE_URL="https://rbtyprmkolqfylcbmgrk.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJidHlwcm1rb2xxZnlsY2JtZ3JrIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU0NzA4NzYsImV4cCI6MjA5MTA0Njg3Nn0.ndpLfN1umOmf7xzxcjYeI8syqJzhZ1pX3KylzYy_wxA"
VITE_SUPABASE_PROJECT_ID="rbtyprmkolqfylcbmgrk"

# --- Paystack (PUBLIC key) --------------------------------------------------
# pk_live_* is Paystack's publishable key — designed to be used client-side and
# exposed in the browser. (The SECRET key sk_live_* must never appear here.)
# This is the variable whose absence breaks Card payment in production.
VITE_PAYSTACK_PUBLIC_KEY=pk_live_8817e88d23370c03310709d607a8c43a4b8757e3

# --- Google Sheets order-sync webhook (OPTIONAL) ----------------------------
# src/lib/googleSheets.ts falls back to a working built-in default when this is
# unset, so leave it commented unless you need to override the Apps Script URL.
# VITE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/XXXXXXXX/exec
